{
  "apiVersion": 3,
  "name": "acf/chat-block",
  "title": "Chat",
  "description": "Display a styled chat conversation between two or more people.",
  "category": "acf-blocks",
  "icon": "format-chat",
  "keywords": ["chat", "conversation", "message", "dialogue", "session"],
  "acf": {
    "renderTemplate": "template.php",
    "blockVersion": 3
  },
  "supports": {
    "align": ["wide", "full"],
    "mode": true,
    "anchor": true,
    "jsx": false
  },
  "styles": [
    {
      "name": "default",
      "label": "Default",
      "isDefault": true
    },
    {
      "name": "terminal",
      "label": "Terminal"
    },
    {
      "name": "minimal",
      "label": "Minimal"
    }
  ],
  "style": "file:./chat-block.css",
  "editorStyle": "file:./chat-block.css",
  "example": {
    "attributes": {
      "mode": "preview",
      "data": {
        "chat_header_title": "Chat Session",
        "chat_messages_0_chat_speaker_name": "Alice",
        "chat_messages_0_chat_speaker_color": "#6366f1",
        "chat_messages_0_chat_message_content": "Hey, have you seen the latest update?",
        "chat_messages_1_chat_speaker_name": "Bob",
        "chat_messages_1_chat_speaker_color": "#10b981",
        "chat_messages_1_chat_message_content": "Yes! It looks great. The new design is much cleaner.",
        "chat_messages": 2
      }
    }
  }
}
